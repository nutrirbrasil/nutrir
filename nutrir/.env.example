# Copie para nutrir/.env.local
# Next.js carrega SOMENTE desta pasta (dev e VPS: ~/nutrir/nutrir/.env.local)
#
# Supabase fica AQUI — não duplique na raiz (.env), a menos que rode o backend Python.

# Supabase — clientes e pedidos (service role, só no servidor)
# Projeto: ocjtzacohamatjbzlind — migrations via MCP (.cursor/mcp.json)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase Auth — login/cadastro (chave pública, pode ir no front)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Telegram — notificações de pedido
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# InfinitePay — Pix e cartão online
INFINITEPAY_HANDLE=nutrir-picarras
NEXT_PUBLIC_SITE_URL=http://89.167.59.77:3001

# WhatsApp — link na tela de pedido pendente (DDI + número, só dígitos)
NEXT_PUBLIC_WHATSAPP_NUMBER=5547992279022

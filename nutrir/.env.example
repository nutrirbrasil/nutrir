# Copie para nutrir/.env.local (NÃO use .env nesta pasta)
#
# Next.js carrega SOMENTE nutrir/.env.local — dev local e VPS:
#   ~/nutricao/nutrir/.env.local
#
# Após alterar NEXT_PUBLIC_*: npm run build && pm2 restart nutrir-web

# Supabase — clientes e pedidos (service role, só no servidor)
# Projeto: ocjtzacohamatjbzlind
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase Auth — login/cadastro (chave pública, pode ir no front)
# Dashboard → Authentication → URL Configuration:
#   Site URL: https://nutrirpicarras.com.br
#   Redirect URLs:
#     http://localhost:3000/auth/callback
#     https://nutrirpicarras.com.br/auth/callback
#
# Login com Google (Authentication → Providers → Google):
#   1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client (Web)
#   2. Authorized redirect URI (copie do Supabase na tela do Google provider):
#      https://<PROJECT_REF>.supabase.co/auth/v1/callback
#   3. Cole Client ID e Client Secret no Supabase e ative o provedor Google
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Telegram — notificações de pedido
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# InfinitePay — Pix e cartão online (redirect usa NEXT_PUBLIC_SITE_URL)
INFINITEPAY_HANDLE=nutrir-picarras
NEXT_PUBLIC_SITE_URL=https://nutrirpicarras.com.br

# WhatsApp — link na tela de pedido pendente (DDI + número, só dígitos)
NEXT_PUBLIC_WHATSAPP_NUMBER=5547992279022

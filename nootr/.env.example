# Frontend (Next.js) — copie para nootr/.env.local
NEXT_PUBLIC_NOOTR_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Backend (FastAPI) — copie para nootr/.env
# A anon key é pública; o RLS do Supabase é o que protege os dados por usuário.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-publica

# IA de interpretação de refeição (texto livre -> alimentos). Segredo de servidor.
IA_PROVIDER=gemini
GEMINI_API_KEY=sua-chave-do-google-ai-studio
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Backend ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

API_HOST=0.0.0.0
API_PORT=8000

# Notificações de pedidos Nutrir (Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Nutrir frontend ──────────────────────────────────────
# Deixe vazio em produção (usa /api/nutrir/* no Next.js).
# Em dev local, só preencha se quiser usar o backend Python.
NEXT_PUBLIC_NUTRIR_API_URL=

# Telegram no Next.js: copie TELEGRAM_* para nutrir/.env.local (dev e VPS)

# ── Nootr frontend ───────────────────────────────────────
NEXT_PUBLIC_NOOTR_API_URL=http://127.0.0.1:8000
